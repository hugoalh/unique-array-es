{
	"$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
	"fmt": {
		"angularNextControlFlowSameLine": true,
		"bracePosition": "sameLine",
		"indentWidth": 4,
		"json.trailingCommas": "never",
		"jsx.bracketPosition": "nextLine",
		"jsx.forceNewLinesSurroundingContent": false,
		"jsx.multiLineParens": "never",
		"lineWidth": 512,
		"newLineKind": "auto",
		"nextControlFlowPosition": "sameLine",
		"operatorPosition": "maintain",
		"proseWrap": "preserve",
		"quoteProps": "asNeeded",
		"semiColons": true,
		"singleBodyPosition": "nextLine",
		"singleQuote": false,
		"sortNamedExports": "caseInsensitive",
		"sortNamedImports": "caseInsensitive",
		"spaceAround": false,
		"spaceSurroundingProperties": true,
		"trailingCommas": "never",
		"typeLiteral.separatorKind": "semiColon",
		"useBraces": "always",
		"useEditorConfig": true,
		"useTabs": true,
		"vueComponentCase": "ignore"
	},
	"imports": { // IMPORTANT: Only for development dependencies!
		"DNT": "jsr:@hugoalh/deno-nodejs-transformer@^0.8.0",
		"NPP": "https://raw.githubusercontent.com/hugoalh/npm-publish-patcher/e39b22aa294786e63ca666898052309972f68094/deno/cli.ts",
		"STD_JSONC": "jsr:@std/jsonc@^1.0.2"
	},
	"lint": {
		"plugins": [
			"jsr:@hugoalh/deno-lint-rules@^0.18.2/presets/library"
		],
		"rules": {
			"tags": [
				"recommended"
			],
			"exclude": [
				"no-import-prefix"
			],
			"include": [
				"default-param-last",
				"eqeqeq",
				"guard-for-in",
				"no-const-assign",
				"no-eval",
				"no-non-null-asserted-optional-chain",
				"no-self-compare",
				"no-slow-types",
				"no-sparse-arrays",
				"no-sync-fn-in-async-fn",
				"no-throw-literal",
				"no-undef",
				"no-useless-rename",
				"triple-slash-reference",
				"verbatim-module-syntax"
			]
		}
	},
	"lock": false,
	"minimumDependencyAge": {
		"age": "P1D",
		"exclude": [
			"jsr:@hugoalh/*",
			"npm:@hugoalh/*"
		]
	},
	"tasks": {
		"jsr-check": {
			"command": "deno task jsr-publish --dry-run --no-provenance",
			"description": "Check for JSR."
		},
		"jsr-publish": {
			"command": "deno publish --allow-dirty --config \"jsr.jsonc\" --no-check",
			"description": "Publish to JSR."
		},
		"npm-codeberg-build": {
			"command": "deno run --allow-all --no-prompt --quiet .npm-codeberg.build.ts",
			"description": "Build for NPM Codeberg."
		},
		"npm-codeberg-check": {
			"command": "deno task npm-codeberg-publish --dry-run",
			"description": "Check for NPM Codeberg."
		},
		"npm-codeberg-publish": {
			"command": "deno run --allow-all --no-prompt --quiet NPP --workspace \"dist/npm-codeberg\" --registry \"codeberg.org/api/packages/hugoalh/npm\"",
			"description": "Publish to NPM Codeberg."
		},
		"npm-github-build": {
			"command": "deno run --allow-all --no-prompt --quiet .npm-github.build.ts",
			"description": "Build for NPM GitHub."
		},
		"npm-github-check": {
			"command": "deno task npm-github-publish --dry-run",
			"description": "Check for NPM GitHub."
		},
		"npm-github-publish": {
			"command": "deno run --allow-all --no-prompt --quiet NPP --workspace \"dist/npm-github\" --registry \"npm.pkg.github.com\"",
			"description": "Publish to NPM GitHub."
		},
		"npm-npm-build": {
			"command": "deno run --allow-all --no-prompt --quiet .npm-npm.build.ts",
			"description": "Build for NPM NPM."
		},
		"npm-npm-check": {
			"command": "deno task npm-npm-publish --dry-run",
			"description": "Check for NPM NPM."
		},
		"npm-npm-publish": {
			"command": "deno run --allow-all --no-prompt --quiet NPP --workspace \"dist/npm-npm\"",
			"description": "Publish to NPM NPM."
		}
	},
	"unstable": [
	]
}
